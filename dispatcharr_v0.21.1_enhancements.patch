+        """Key for stream/profile combination cooldown (failed combinations).
+        TTL = stream_cooldown_minutes * 60. Redis auto-deletes after expiry."""
+        return f"ts_proxy:channel:{channel_id}:cooldown:{stream_id}:{profile_id}"

