################################################################################
# BUGFIX 4: HTTPStreamReader Race Condition on Stop
################################################################################
#
# Root cause: stop() closes self.response while _read_stream() thread is still
# iterating iter_content(). This causes:
#   AttributeError: 'NoneType' object has no attribute 'read'
#
# Fix: Catch AttributeError/TypeError in _read_stream() - these are expected
# when the reader is stopped externally while streaming.

--- a/apps/proxy/ts_proxy/http_streamer.py
+++ b/apps/proxy/ts_proxy/http_streamer.py
@@ except block in _read_stream() @@
-        except Exception as e:
-            logger.error(f"HTTP reader unexpected error: {e}", exc_info=True)
+        except (AttributeError, TypeError):
+            # Race condition: response closed by stop() while iter_content() was running
+            if self.running:
+                logger.error(f"HTTP reader connection lost unexpectedly for {self.url}")
+            else:
+                logger.debug(f"HTTP reader stopped cleanly for {self.url}")
+        except Exception as e:
+            logger.error(f"HTTP reader unexpected error: {e}", exc_info=True)

