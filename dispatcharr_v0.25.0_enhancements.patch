### File: apps/output/views.py
Lines: 32-130

```python
# NEW FUNCTION 1: get_basic_auth_user()
def get_basic_auth_user(request):
    """
    Extract and authenticate user from HTTP Basic Auth header.
    Returns User object if valid, None otherwise.
    """
    auth_header = request.META.get('HTTP_AUTHORIZATION', '')
    
    if not auth_header.startswith('Basic '):
        return None
    
    try:
        # Decode base64 credentials
        import base64
        auth_decoded = base64.b64decode(auth_header[6:]).decode('utf-8')
        username, password = auth_decoded.split(':', 1)
        
        # Authenticate
        from django.contrib.auth import authenticate
        user = authenticate(username=username, password=password)
        
        if user and user.is_active:
            return user
    except Exception as e:
        logger.error(f"Basic auth failed: {e}")
    
    return None

# NEW FUNCTION 2: require_basic_auth()
def require_basic_auth(request):
    """
    Decorator/helper to require HTTP Basic Auth.
    Returns 401 with WWW-Authenticate header if auth fails.
    """
    user = get_basic_auth_user(request)
    
    if not user:
        from django.http import HttpResponse
        response = HttpResponse('Unauthorized', status=401)
        response['WWW-Authenticate'] = 'Basic realm="Dispatcharr"'
        return response
    
    return user

# INTEGRATION in m3u_endpoint()
def m3u_endpoint(request):
    # Try API key first
    user = get_user_from_api_key(request)
    
    # Fall back to Basic Auth
    if not user:
        auth_result = require_basic_auth(request)
        if isinstance(auth_result, HttpResponse):
            return auth_result
        user = auth_result
    
    # ... rest of function

# INTEGRATION in epg_endpoint()
