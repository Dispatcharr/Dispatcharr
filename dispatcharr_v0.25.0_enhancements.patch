### 5.5 get_alternate_streams() Enhancement
File: apps/proxy/live_proxy/url_utils.py
Line: ~284

```python
def get_alternate_streams(channel_id: str, current_stream_id: int = None, current_profile_id: int = None):
    """
    Get alternate streams for a channel, including ALL profiles per stream.
    
    Returns list of dicts with stream_id, profile_id, stream_url, user_agent.
    """
    from apps.channels.models import Channel
    from apps.m3u.models import M3UAccountProfile
    
    try:
        channel = Channel.objects.get(id=channel_id)
        alternate_streams = []
        
        for stream in channel.streams.all():
            # Get ALL profiles for this stream's M3U account
            profiles = M3UAccountProfile.objects.filter(
                m3u_account=stream.m3u_account,
                is_active=True
            ).order_by('priority')
            
            for profile in profiles:
                # Do NOT skip current stream entirely - we want to try other profiles
                # Only skip the exact (stream_id, profile_id) combination we just tried
                if stream.id == current_stream_id and profile.id == current_profile_id:
                    continue
                
                stream_url = stream.get_stream_url(profile=profile)
                alternate_streams.append({
                    'stream_id': stream.id,
                    'profile_id': profile.id,
                    'stream_url': stream_url,
                    'user_agent': stream.m3u_account.get_user_agent(),
                })
        
        return alternate_streams
    except Exception as e:
        logger.error(f"Error getting alternate streams: {e}")
        return []
```

