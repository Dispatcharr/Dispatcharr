### 5.4 get_stream_info_for_profile() Function
File: apps/proxy/live_proxy/url_utils.py
Line: ~573

```python
# NEW FUNCTION
def get_stream_info_for_profile(channel_id: str, stream_id: int, m3u_profile_id: int) -> dict:
    """
    Get stream information for a specific stream ID and M3U profile ID combination.
    
    This allows trying different profile credentials for the same stream,
    which is essential for profile failover.
    """
    from apps.channels.models import Channel
    from apps.m3u.models import M3UAccountProfile
    
    try:
        channel = Channel.objects.get(id=channel_id)
        stream = channel.streams.filter(id=stream_id).first()
        
        if not stream:
            return {}
        
        # Get the specific profile
        profile = M3UAccountProfile.objects.filter(
            m3u_account=stream.m3u_account,
            id=m3u_profile_id
        ).first()
        
        if not profile:
            return {}
        
        # Build stream URL with profile credentials
        stream_url = stream.get_stream_url(profile=profile)
        
        return {
            'stream_id': stream_id,
            'stream_url': stream_url,
            'user_agent': stream.m3u_account.get_user_agent(),
            'profile_id': m3u_profile_id,
        }
    except Exception as e:
        logger.error(f"Error getting stream info for profile: {e}")
        return {}
